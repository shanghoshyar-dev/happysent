# Site URL for canonical links, Open Graph, sitemap and robots (no trailing slash).
# Lokalt: NEXT_PUBLIC_SITE_URL=http://localhost:3000  (eller den port Next visar i terminalen)
NEXT_PUBLIC_SITE_URL=https://happysent.com
# Auth/inbjudningar: använd alltid produktion om NEXT_PUBLIC_SITE_URL är localhost (sätt ALLOW_LOCALHOST_AUTH=1 för lokal test).
# AUTH_SITE_URL=https://happysent.com

# Google Analytics 4 (valfritt — utan ID laddas ingen spårning)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Email + cron
ADMIN_EMAIL=
CRON_SECRET=

# HappySent-utfärdare på kundfaktura-PDF (valfritt)
HAPPYSENT_LEGAL_NAME=HappySent
HAPPYSENT_ADDRESS=Malmö, Sverige
HAPPYSENT_ORG_NUMBER=
HAPPYSENT_VAT_NUMBER=
HAPPYSENT_BANKGIRO=
HAPPYSENT_BILLING_EMAIL=info@happysent.com
